        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Sequence Diagram: validateAndCreateDelivery\n\n&#39; Style alignment configurations\nskinparam BoxPadding 10\nskinparam ParticipantPadding 10\n\nbox \&quot;Transportation Module\&quot; #LightBlue\nparticipant \&quot;TransportController\&quot; as ctrl\nparticipant \&quot;TransportService\&quot; as service\nparticipant \&quot;TransportFacade\&quot; as facade\nparticipant \&quot;DeliveryDL\&quot; as delivery\nparticipant \&quot;TransportDAO\&quot; as dao\nend box\n\nbox \&quot;Employees Module\&quot; #LightYellow\nparticipant \&quot;ShiftService\&quot; as empShift\nend box\n\n&#39; System operation invocation\n[-&gt; ctrl : validateAndCreateDelivery(date, shiftType, truckId, destStoreId, cargo)\nactivate ctrl\n\nctrl -&gt; service : createDelivery(date, shiftType, truckId, destStoreId, cargo)\nactivate service\n\nservice -&gt; facade : createDelivery(date, shiftType, truckId, destStoreId, cargo)\nactivate facade\n\n&#39; GRASP: Information Expert - ShiftService knows employee constraints\nfacade -&gt; empShift : getScheduledDriverWithLicense(date, shiftType, truckId)\nactivate empShift\nempShift --&gt; facade : validDriverId\ndeactivate empShift\n\nalt validDriverId != null\n    &#39; GRASP: Information Expert - Checking for warehouseman presence at destination\n    facade -&gt; empShift : isRoleScheduled(date, shiftType, destStoreId, \&quot;Warehouseman\&quot;)\n    activate empShift\n    empShift --&gt; facade : isWarehousemanPresent\n    deactivate empShift\n\n    alt isWarehousemanPresent == true\n        &#39; GRASP: Creator pattern - Facade orchestrates creation of the domain entity\n        facade -&gt; delivery ** : create(date, shiftType, validDriverId, truckId, destStoreId, cargo)\n        \n        facade -&gt; dao : saveDelivery(deliveryInstance)\n        activate dao\n        dao --&gt; facade : success\n        deactivate dao\n        \n        facade --&gt; service : success\n    else isWarehousemanPresent == false\n        facade --&gt; service : error(\&quot;No warehouseman at destination\&quot;)\n    end\nelse validDriverId == null\n    facade --&gt; service : error(\&quot;No qualified driver scheduled\&quot;)\nend\n\nservice --&gt; ctrl : response\ndeactivate facade\ndeactivate service\n\n[&lt;-- ctrl : response\ndeactivate ctrl\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="mLvuEx4mHDMJJRAyf1kM-3">
